FINCORE_ENV=development
FINCORE_DATABASE_URL=postgresql+psycopg://fincore:fincore@postgres:5432/fincore
FINCORE_REDIS_URL=redis://redis:6379/0
FINCORE_JWT_SECRET=replace-with-at-least-32-random-characters
FINCORE_ACCESS_TOKEN_MINUTES=15
FINCORE_REFRESH_TOKEN_DAYS=7
FINCORE_CORS_ORIGINS=http://localhost:3000
FINCORE_ALLOWED_HOSTS=localhost,127.0.0.1,api,testserver
FINCORE_PROVIDER_MODE=development
FINCORE_WEBHOOK_WORKER_ENABLED=true
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

FINCORE_RATE_LIMIT_PER_MINUTE=120
